# 공유 MongoDB Atlas / shared MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/offduty?retryWrites=true&w=majority
MONGODB_DB=offduty
STORE_ID=store_001

# Runtime: Vertex AI (권장 — gcloud ADC 인증, free-tier rate limit 없음, 트랙 크레딧).
# Vertex AI runtime (recommended): auth via `gcloud auth application-default login`.
USE_VERTEX=true
GCP_PROJECT=off-duty-rapidthon
GCP_LOCATION=global

# Gemini 모델명(설정). USE_VERTEX=false 일 때만 GEMINI_API_KEY(AI Studio) 필요.
# Model names. GEMINI_API_KEY (AI Studio) is only needed when USE_VERTEX=false.
GEMINI_API_KEY=
AGENT_MODEL=gemini-3-flash-preview
ROUTER_MODEL=gemini-3-flash-preview
# Optional GA safety net (only used if the primary 404s). Leave empty to stay 100% Gemini 3.
AGENT_MODEL_FALLBACK=

# MongoDB MCP server launch / MCP 서버 실행 (콤마구분 args)
MCP_COMMAND=npx
MCP_ARGS=-y,mongodb-mcp-server
